{
  "branches": ["master"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    [
      "@google/semantic-release-replace-plugin",
      {
        "replacements": [
          {
            "files": ["CMakeLists.txt"],
            "from": "set\\(VERSION \\d[\\d.]*\\)",
            "to": "set(VERSION ${nextRelease.version})",
            "results": [
              {
                "file": "CMakeLists.txt",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          },
          {
            "files": ["vcpkg.json"],
            "from": "\"version-string\": \".*\"",
            "to": "\"version-string\": \"${nextRelease.version}\"",
            "results": [
              {
                "file": "vcpkg.json",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "draftRelease": true
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CMakeLists.txt", "vcpkg.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
